from abc import ABC,abstractmethod
class shape(ABC):
    def show(self):
        print("This is shape")
    @abstractmethod
    def area(self):
        pass
class square(shape):
    def __init__(self,r):
        self.r=r
    def area(self):
        print("Area=",self.r*self.r)
a=square(2)
a.show()
a.area()